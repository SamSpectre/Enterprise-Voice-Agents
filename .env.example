# ElevenLabs
ELEVENLABS_API_KEY=
AGENT_ID=

# Webhook security — HMAC-SHA256 signature verification
# Set this to the signing secret from ElevenLabs webhook settings
ELEVENLABS_WEBHOOK_SECRET=

# Server
HOST=0.0.0.0
PORT=8000

# API authentication — Bearer token for REST endpoints (/api/*)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# CORS — comma-separated list of allowed origins
# Example: https://your-app.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=60

# Audio upload size limit in MB
MAX_AUDIO_SIZE_MB=50

# Disable Swagger/ReDoc in production
DISABLE_DOCS=false
